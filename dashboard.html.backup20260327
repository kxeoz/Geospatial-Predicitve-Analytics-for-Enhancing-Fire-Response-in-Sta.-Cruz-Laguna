            <div class="p-6 overflow-y-auto flex-grow">
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-4 py-3 text-left text-xs font-bold text-gray-500 uppercase">ID</th>
                                <th class="px-4 py-3 text-left text-xs font-bold text-gray-500 uppercase">Date</th>
                                <th class="px-4 py-3 text-left text-xs font-bold text-gray-500 uppercase">Occupancy</th>
                                <th class="px-4 py-3 text-left text-xs font-bold text-gray-500 uppercase">Location</th>
                                <th class="px-4 py-3 text-left text-xs font-bold text-gray-500 uppercase">Action</th>
                            </tr>
                        </thead>
                        <tbody id="barangayIncidentsTableBody" class="bg-white divide-y divide-gray-200">
                            <!-- Data injected here -->
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="p-4 border-t bg-gray-50 text-right">
                <button onclick="closeBarangayModal()" class="px-6 py-2 bg-gray-800 text-white rounded-lg font-bold hover:bg-gray-900 transition-colors">
                    Close
                </button>
            </div>
        </div>
    </div>

    <!-- Full Report Modal -->
    <div id="reportModal" class="fixed inset-0 bg-black bg-opacity-50 z-50 hidden flex items-center justify-center p-4">
        <div class="bg-white rounded-xl shadow-2xl max-w-4xl w-full max-h-[90vh] overflow-hidden flex flex-col">
            <div class="fire-theme p-4 flex justify-between items-center text-white" style="background: linear-gradient(135deg, #dc2626 0%, #991b1b 100%);">
                <h2 class="text-xl font-bold flex items-center">
                    <i data-feather="file-text" class="mr-2"></i>
                    Full Incident Report Details
                </h2>
                <button onclick="closeFullReport()" class="hover:bg-red-700 p-1 rounded-full">
                    <i data-feather="x"></i>
                </button>
            </div>
            <div id="modalContent" class="p-6 overflow-y-auto grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Content will be injected here -->
            </div>
            <div class="p-4 bg-gray-50 border-t flex justify-end gap-3">
                <button onclick="editReport()" class="px-6 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg font-semibold flex items-center">
                    <i data-feather="edit" class="w-4 h-4 mr-2"></i> Edit Report
                </button>
                <button onclick="closeFullReport()" class="px-6 py-2 bg-gray-800 text-white rounded-lg font-semibold">
                    Close
                </button>
            </div>
        </div>
    </div>

    <script src="js/script.js"></script>
    <script src="js/hydrants-manager.js"></script>
