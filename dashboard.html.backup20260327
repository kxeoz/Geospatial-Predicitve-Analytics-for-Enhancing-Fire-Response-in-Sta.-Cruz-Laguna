    <script>
        console.log('🚀 Dashboard initialization script starting');
        
        // Global flags
        let mapsReady = false;
        let mapsError = null;
        let initMapAttempts = 0;
        
        // Function to display error on map container
        function showMapError(message, details = '') {
            console.error('❌ Map Error:', message, details);
            const mapContainer = document.getElementById('map');
            if (mapContainer) {
                mapContainer.innerHTML = `
                    <div style="display:flex; align-items:center; justify-content:center; height:100%; background:#f3f4f6; color:#dc2626; font-family:sans-serif;">
                        <div style="text-align:center; padding:20px; max-width:400px;">
                            <div style="font-size:48px; margin-bottom:10px;">⚠️</div>
                            <div style="font-weight:bold; margin-bottom:5px; font-size:16px;">Map Failed to Load</div>
                            <div style="font-size:13px; color:#666; margin-bottom:10px;">${message}</div>
                            ${details ? `<div style="font-size:11px; color:#999; background:#fff; padding:10px; border-radius:4px; margin-bottom:10px; font-family:monospace;">${details}</div>` : ''}
                            <div style="font-size:11px; color:#999;">Check browser console (F12) for details</div>
                        </div>
                    </div>
                `;
            }
        }
        
        // Google Maps callback - will be called when API loads
        function initMapCallback() {
            console.log('✅ Google Maps callback fired');
            mapsReady = true;
            console.log('Google Maps API State:', {
                googleDefined: typeof window.google !== 'undefined',
                googleMapsDefined: typeof window.google?.maps !== 'undefined',
                initMapDefined: typeof initMap !== 'undefined'
            });
            
            if (typeof initMap === 'function') {
                try {
                    console.log('Calling initMap from callback');
                    initMap();
                    console.log('✅ initMap succeeded from callback');
                } catch (e) {
                    console.error('❌ initMap threw error:', e);
                    showMapError('Map initialization failed', e.message);
                }
            } else {
                console.warn('⚠️ initMap not available in callback, will be called by polling');
            }
        }
        
        // Aggressive polling to ensure Google Maps initializes
        function ensureMapsInitialized() {
            initMapAttempts++;
            
            // Logging every 5 attempts to reduce noise
            if (initMapAttempts % 10 === 1) {
                console.log(`🔄 Map init poll attempt ${initMapAttempts}...`, {
                    google: typeof window.google,
                    'google.maps': typeof window.google?.maps,
                    initMap: typeof initMap,
                    mapObject: typeof map
                });
            }
            
            // Give up after 100 attempts (10 seconds)
            if (initMapAttempts > 100) {
                console.error('❌ Gave up after 100 attempts. Final state:', {
                    google: typeof window.google,
                    'google.maps': typeof window.google?.maps,
                    mapsReady: mapsReady,
                    initMap: typeof initMap,
                    mapObject: typeof map,
                    htmlMapElement: document.getElementById('map') ? 'EXISTS' : 'NOT FOUND'
                });
                
                // Check what went wrong
                let errorMsg = 'Unknown error';
                if (typeof window.google === 'undefined') {
                    errorMsg = 'Google Maps API not available (window.google not defined)';
                } else if (typeof window.google?.maps === 'undefined') {
                    errorMsg = 'Google Maps library not available (google.maps not defined)';
                } else if (typeof initMap !== 'function') {
                    errorMsg = 'initMap function not defined in script.js';
                }
                
                showMapError('Unable to initialize map', errorMsg);
                return;
            }
            
            // Check if Google Maps API is available
            if (typeof window.google !== 'undefined' && typeof window.google.maps !== 'undefined') {
                if (map === null || map === undefined) {
                    console.log('✅ Google Maps available, calling initMap');
                    if (typeof initMap === 'function') {
                        try {
                            initMap();
                            console.log('✅ Map initialized successfully');
                            return;
                        } catch (err) {
                            console.error('❌ Error in initMap:', err);
                            console.error('Stack trace:', err.stack);
                            showMapError('Map initialization error', err.message || 'Unknown error in initMap function');
                            return;
                        }
                    } else {
                        console.warn('⚠️ initMap function still not defined');
                    }
                } else {
                    // Map is already initialized
                    if (initMapAttempts <= 10) {
                        console.log('ℹ️ Map already initialized');
                    }
                    return;
                }
            }
            
            // Keep polling
            setTimeout(ensureMapsInitialized, 100);
        }
        
        // Start polling when DOMContentLoaded fires
        window.addEventListener('DOMContentLoaded', () => {
            console.log('📍 DOMContentLoaded event fired');
            // Start aggressive polling after a small delay to let scripts load
            setTimeout(() => {
                console.log('🎯 Starting map initialization polling sequence');
                ensureMapsInitialized();
            }, 300);
        });
        
        console.log('✅ Dashboard initialization script loaded');
    </script>
    <script>
        // Monitor for Google Maps script load
        window.addEventListener('load', () => {
            console.log('📄 Page fully loaded');
            console.log('Google Maps availability:', {
                google: typeof window.google,
                'google.maps': typeof window.google?.maps,
                callback: typeof initMapCallback
            });
            
            if (typeof window.google === 'undefined') {
                console.error('❌ Google object not found - API may not have loaded');
                // Try to show error after a small delay
                setTimeout(() => {
                    if (typeof window.google === 'undefined') {
                        showMapError('Google Maps API not available', 'The Google Maps script may have failed to load');
                    }
                }, 1000);
            }
        });
    </script>
    <!-- Google Maps API with error handling -->
    <script>
        console.log('📡 About to load Google Maps API script');
        
        // Create a timeout to detect if API never loads
        let googleMapsLoadTimeout = setTimeout(() => {
            if (typeof window.google === 'undefined' || typeof window.google?.maps === 'undefined') {
                console.error('⏱️ TIMEOUT: Google Maps API did not load within 8 seconds');
                if (typeof showMapError === 'function') {
                    showMapError(
                        'Google Maps API Timeout',
                        'The API took too long to load. Check your internet connection and API key.'
                    );
                }
            }
        }, 8000);
        
        // Track if Google Maps API loaded
        window.googleMapsScriptTag = document.createElement('script');
        window.googleMapsScriptTag.src = 'https://maps.googleapis.com/maps/api/js?key=AIzaSyApuqCxMy07vqb1Ufn450Fp0tBWMAcp_pE&libraries=places,routes&callback=initMapCallback';
        window.googleMapsScriptTag.async = true;
        window.googleMapsScriptTag.defer = true;
        
        window.googleMapsScriptTag.addEventListener('load', () => {
            clearTimeout(googleMapsLoadTimeout);
            console.log('✅ Google Maps script loaded successfully');
            console.log('Checking for window.google:', typeof window.google);
        });
        
        window.googleMapsScriptTag.addEventListener('error', (e) => {
            clearTimeout(googleMapsLoadTimeout);
            console.error('❌ Google Maps API script failed to load', e);
            console.error('Error details:', {
                message: e.message,
                filename: e.filename,
                type: e.type
            });
            if (typeof showMapError === 'function') {
                showMapError(
                    'Failed to load Google Maps',
                    'Network error or invalid API key. Details in console.'
                );
            }
        });
        
        // Append to document
        (document.head || document.documentElement).appendChild(window.googleMapsScriptTag);
        console.log('📝 Google Maps script tag added to document');
    </script>
    </script>
    <script>
        // Check for session before rendering
        const loggedIn = localStorage.getItem('bfp_admin_logged_in');
        if (!loggedIn) {
            window.location.href = '/login';
        }
        
        // Parse user info to check role
        let currentUser = null;
        try {
            const userData = localStorage.getItem('bfp_admin_user');
            currentUser = userData ? JSON.parse(userData) : null;
        } catch (e) {
            console.error("Error parsing user data", e);
            // Fallback for old simple username storage
            currentUser = { username: localStorage.getItem('bfp_admin_user'), role: 'admin' };
        }

        // Apply role-based restrictions
        document.addEventListener('DOMContentLoaded', () => {
            if (currentUser && currentUser.role === 'user') {
                // Hide restricted navigation items for regular users
                const restrictedSections = ['analysis'];
                restrictedSections.forEach(section => {
                    const navBtns = document.querySelectorAll(`.nav-btn[data-section="${section}"]`);
                    navBtns.forEach(btn => btn.classList.add('hidden'));
                });
                
                // Also hide in mobile menu if it exists
                const mobileNavBtns = document.querySelectorAll(`.nav-btn-mobile[data-section]`);
                mobileNavBtns.forEach(btn => {
                    if (restrictedSections.includes(btn.getAttribute('data-section'))) {
                        btn.classList.add('hidden');
                    }
                });

                console.log("Applied role-based restrictions for 'user' role");
            }
        });
    </script>
